# Imagem Docker Hub (usuario/nome-da-imagem)
DOCKER_IMAGE=wallesonferreira/festa-com-ia

# Supabase — obrigatórios em build time (NEXT_PUBLIC_* são embutidos no bundle)
# Usados apenas para Auth + profiles
# Encontre em: https://supabase.com/dashboard/project/<project-id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# URL pública da aplicação usada no build para metadata e links absolutos.
NEXT_PUBLIC_SITE_URL=https://festacomia.pro

# DATABASE_URL — NÃO é build arg (runtime only)
# Definida no docker-compose.yml via environment: ou no .env do compose
