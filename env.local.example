# Renomeie este arquivo para .env.local e preencha com suas credenciais

# Supabase — usado no cliente (Auth + profiles)
# Encontre em: https://supabase.com/dashboard/project/<project-id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Supabase — usado apenas no backend para exclusão total da conta
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Postgres local — usado para todos os dados operacionais
DATABASE_URL=postgresql://festacomia:<senha>@localhost:5432/festacomia

# Webhook n8n para envio de mensagens WhatsApp (opcional em desenvolvimento)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/send-message

# URL pública da aplicação em dev/build local
NEXT_PUBLIC_SITE_URL=http://localhost:3000