# Stack do n8n no Portainer / docker compose
# Copie este arquivo para env.local, .env ou preencha as variáveis no Portainer.

# Banco próprio do n8n
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=change_me_n8n_db_password

# Chave de criptografia do n8n
N8N_ENCRYPTION_KEY=change_me_to_a_long_random_secret

# Redis interno usado no modo fila (cole as stacks na mesma rede `web` do Portainer)
N8N_QUEUE_REDIS_PASSWORD=change_me_n8n_queue_redis_password

# Fuso horário
TZ=America/Sao_Paulo
GENERIC_TIMEZONE=America/Sao_Paulo

# Acesso ao editor e webhooks
# Em produção, troque para seu domínio real.
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678/
N8N_SECURE_COOKIE=false
