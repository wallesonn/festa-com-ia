# Copie este arquivo para o Portainer (ou para um .env do stack) e preencha os valores reais.
#
# Este arquivo reúne:
# - variáveis do stack do Portainer (runtime)
# - variáveis opcionais de build, caso você vá rebuildar a imagem na VPS

########################################
# STACK / RUNTIME (Portainer)
########################################

# Domínio público da aplicação usado pelo Traefik e pela URL pública do app.
APP_DOMAIN=festacomia.pro

# Versão da imagem Docker a ser usada no deploy.
# Se ficar em branco, o docker-compose usa latest.
IMAGE_TAG=latest

# Banco operacional local no VPS
POSTGRES_DB=festacomia
POSTGRES_USER=festacomia
POSTGRES_PASSWORD=senha123

# Redis usado pelo stack
REDIS_PASSWORD=senha123

# URL do webhook n8n para envio de mensagens WhatsApp (opcional).
# Se não definido, mensagens ficam salvas como pending_send no Postgres sem disparar o n8n.
#
# Formato dependendo da topologia:
#   - n8n no mesmo VPS, na rede Docker "web":  http://n8n:5678/webhook/send-message
#   - n8n no mesmo VPS, porta exposta no host: http://host.docker.internal:5678/webhook/send-message
#   - n8n com domínio via Traefik:             https://n8n.festacomia.pro/webhook/send-message
N8N_WEBHOOK_URL=http://n8n:5678/webhook/send-message

########################################
# BUILD TIME (somente se você for rebuildar a imagem)
########################################

# Imagem Docker Hub (usuario/nome-da-imagem)
DOCKER_IMAGE=wallesonnn/festa-com-ia

# URL pública da aplicação usada no build para metadata e links absolutos.
NEXT_PUBLIC_SITE_URL=https://festacomia.pro

# Supabase — usados no build da imagem porque NEXT_PUBLIC_* entram no bundle
# Encontre em: https://supabase.com/dashboard/project/<project-id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://ajggojpmtckfbgujwsbe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFqZ2dvanBtdGNrZmJndWp3c2JlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ5ODk1NTUsImV4cCI6MjA5MDU2NTU1NX0.Avd7q1GJHDLJ-SklVCVoifpwFolKNpoNMw3ezx2xmGc


########################################
# OBSERVAÇÕES
########################################

# - Se você for apenas subir o stack no Portainer com uma imagem já publicada,
#   as variáveis obrigatórias são: APP_DOMAIN, IMAGE_TAG, POSTGRES_DB,
#   POSTGRES_USER, POSTGRES_PASSWORD e REDIS_PASSWORD.
# - NEXT_PUBLIC_SUPABASE_URL e NEXT_PUBLIC_SUPABASE_ANON_KEY só são necessários
#   se você for rodar ./build.sh para gerar e enviar uma nova imagem.
# - NEXT_PUBLIC_SITE_URL também pode ser definido no Portainer para alinhar
#   metadata, links absolutos e o domínio público da aplicação.
